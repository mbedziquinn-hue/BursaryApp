<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F2B48"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome Back!"
        android:textColor="#80DEEA"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Log in to your account"
        android:textColor="#E0F7FA"
        android:textSize="14sp"
        android:layout_marginBottom="40dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Email" android:textColor="#E0F7FA" android:textSize="16sp"/>
    <EditText
        android:id="@+id/edtLoginEmail"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Enter your email"
        android:inputType="textEmailAddress"
        android:backgroundTint="#80DEEA"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="20dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Password" android:textColor="#E0F7FA" android:textSize="16sp"/>
    <EditText
        android:id="@+id/edtLoginPassword"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Enter your password"
        android:inputType="textPassword"
        android:backgroundTint="#80DEEA"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot password?"
        android:textColor="#4DB6AC"
        android:textSize="14sp"
        android:layout_gravity="end"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="LOG IN"
        android:textColor="#000000"
        android:textStyle="bold"
        android:backgroundTint="#4DB6AC"/>

</LinearLayout>