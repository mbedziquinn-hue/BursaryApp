<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:background="#1A3A5C">

    <!-- Bursary Name -->
    <TextView
        android:id="@+id/tvAppliedName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        tools:text="Bursary Name" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <!-- Date Applied -->
        <TextView
            android:id="@+id/tvAppliedDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#80DEEA"
            android:textSize="12sp"
            tools:text="Applied: 04 May 2026" />

        <!-- Status -->
        <TextView
            android:id="@+id/tvAppliedStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFD600"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="#33FFD600"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            tools:text="PENDING" />
    </LinearLayout>

</LinearLayout>